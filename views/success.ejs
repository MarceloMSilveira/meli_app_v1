<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Conta conectada — MeliSync for GDA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --yellow: #FFE600;
      --dark: #1A1A18;
      --bg: #FFFDF7;
      --card-bg: #ffffff;
      --border: #E8E6DE;
      --text-muted: #888888;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      color: var(--dark);
    }

    .topbar {
      background: var(--yellow);
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .topbar-left {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    .topbar-logo {
      font-family: 'Sora', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--dark);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .topbar-logo-text {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .topbar-by {
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      color: var(--dark);
      opacity: 0.5;
    }

    .main {
      max-width: 480px;
      margin: 3rem auto;
      padding: 0 1.5rem;
    }

    .success-card {
      background: var(--dark);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      text-align: center;
      margin-bottom: 1rem;
    }

    .success-icon {
      width: 64px;
      height: 64px;
      background: var(--yellow);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.25rem;
      font-size: 28px;
      font-weight: 700;
      color: var(--dark);
    }

    .success-title {
      font-family: 'Sora', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--yellow);
      margin-bottom: 8px;
    }

    .success-sub {
      font-size: 14px;
      color: #777;
    }

    .info-card {
      background: var(--card-bg);
      border-radius: 14px;
      border: 0.5px solid var(--border);
      padding: 0 1.25rem;
      margin-bottom: 1rem;
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 0;
      border-bottom: 0.5px solid var(--border);
    }

    .info-row:last-child { border-bottom: none; }

    .info-label {
      font-size: 13px;
      color: var(--text-muted);
    }

    .info-value {
      font-family: 'Sora', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: var(--dark);
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 0.5rem;
    }

    .btn-primary {
      flex: 1;
      background: var(--dark);
      color: var(--yellow);
      font-family: 'Sora', sans-serif;
      font-size: 14px;
      font-weight: 600;
      border: none;
      border-radius: 12px;
      padding: 14px;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
      transition: opacity 0.15s;
    }

    .btn-primary:hover { opacity: 0.85; }

    .btn-ghost {
      flex: 1;
      background: transparent;
      color: var(--text-muted);
      font-family: 'Sora', sans-serif;
      font-size: 14px;
      font-weight: 500;
      border: 0.5px solid var(--border);
      border-radius: 12px;
      padding: 14px;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
      transition: background 0.15s;
    }

    .btn-ghost:hover { background: #f5f3eb; }

    .footer {
      text-align: center;
      padding: 2rem;
      font-size: 12px;
      color: #bbb;
    }
  </style>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
</head>
<body>

  <header class="topbar">
    <div class="topbar-left">
      <div class="topbar-logo">
        <svg width="32" height="32" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" style="display:block;flex-shrink:0;">
          <rect width="200" height="200" rx="44" fill="#1A1A18"/>
          <path d="M100 36 A64 64 0 1 1 36 100" fill="none" stroke="#FFE600" stroke-width="18" stroke-linecap="round"/>
          <polygon points="31,78 31,116 62,97" fill="#FFE600"/>
          <text x="100" y="122" text-anchor="middle" font-family="'Sora', Georgia, sans-serif" font-size="66" font-weight="700" fill="#FFE600">M</text>
        </svg>
        <div class="topbar-logo-text">
          <span>MeliSync</span><span>for GDA</span>
        </div>
      </div>
      <span class="topbar-by">by MS1 Softwares</span>
    </div>
  </header>

  <main class="main">

    <div class="success-card">
      <div class="success-icon">✓</div>
      <p class="success-title">Conta conectada!</p>
      <p class="success-sub">Tudo certo, já pode sincronizar</p>
    </div>

    <div class="info-card">
      <div class="info-row">
        <span class="info-label">Usuário</span>
        <span class="info-value"><%= account.nickname %></span>
      </div>
      <div class="info-row">
        <span class="info-label">ID Mercado Livre</span>
        <span class="info-value"><%= account.meli_user_id %></span>
      </div>
      <% if (account.email) { %>
      <div class="info-row">
        <span class="info-label">E-mail</span>
        <span class="info-value"><%= account.email %></span>
      </div>
      <% } %>
      <% if (account.country_id && account.site_id) { %>
      <div class="info-row">
        <span class="info-label">País / Site</span>
        <span class="info-value"><%= account.country_id %> · <%= account.site_id %></span>
      </div>
      <% } %>
    </div>

    <div class="actions">
      <a href="/" class="btn-primary">Ver contas</a>
      <a href="/auth/mercadolivre" class="btn-ghost">Conectar outra</a>
    </div>

  </main>

  <footer class="footer">
    MeliSync for GDA · MS1 Softwares
  </footer>

</body>
</html>
